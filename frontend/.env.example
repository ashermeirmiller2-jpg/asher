# Base URL of the Munchy's Grill backend API (FastAPI).
# Used by the in-app checkout, contact form, and the /admin dashboard.
#
# Local dev example:
#   REACT_APP_BACKEND_URL=http://localhost:8000
#
# On Vercel: set this in Project Settings → Environment Variables, pointing at
# wherever the FastAPI backend is hosted. Leave unset for a static, front-end
# only deploy (menu browsing + cart work; order/contact submission will not).
REACT_APP_BACKEND_URL=
