{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps && python -m pip install -r requirements.txt",
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{frontend/**,test_reports/**,tests/**,memory/**,backend/tests/**,**/__pycache__/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
